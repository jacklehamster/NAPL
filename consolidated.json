  "/example/package.json": {
    "name": "example",
    "module": "src/index.ts",
    "type": "module",
    "scripts": {
      "start": "bun run build && bun --watch index.ts",
      "start:prod": "bun run build && NODE_ENV=production bun --watch index.ts",
      "build": "bun i && bun run build-icon && bun run copy-workers && bun run bundler/bundler.ts",
      "build-icon": "mkdir -p icons && icon-gen -i ../icon.png -o ./icons",
      "dev": "bun run build && bun --watch index.ts",
      "copy-workers": "mv ./dist ./dist-bak && rm -rf ./dist-bak && mkdir -p dist && bun run copy-signal-worker && bun run copy-app-worker",
      "copy-signal-worker": "cp ../node_modules/@dobuki/hello-worker/dist/signal-room.worker.js* ./dist",
      "copy-app-worker": "cp ../dist/worker/app.worker.js* ./dist"
    },
    "devDependencies": {
      "@types/express": "^5.0.6",
      "bun-lightningcss": "^0.2.0",
      "bun-types": "^1.3.6",
      "dotenv": "^16.6.1",
      "express": "^4.22.1",
      "icon-gen": "^4.0.0",
      "png-to-ico": "^2.1.8",
      "serve-static-bun": "^0.5.3"
    },
    "peerDependencies": {
      "typescript": "^5.9.3"
    },
    "dependencies": {
      "napl": "link:napl",
      "@types/random-name": "^0.1.2",
      "generate-random-emoji": "^1.0.2",
      "json-stringify-pretty-compact": "^4.0.0",
      "random-name": "^0.1.2",
      "unique-names-generator": "^4.7.1"
    }
  },
